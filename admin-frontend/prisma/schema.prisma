// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid())
  firstName     String
  lastName      String
  email         String       @unique
  pendingEmail  String?
  emailVerificationOtp String?
  phone         String?
  password      String
  username           String       @unique
  lastUsernameChange DateTime?
  avatarUrl          String?
  coverUrl           String?
  walletBalance      Float        @default(0.0)
  
  // Optional Onboarding Fields
  country       String?
  state         String?
  lga           String?
  occupation    String?
  gender        String?
  bio           String?      @db.Text
  creatorType   String?
  interests     Json?        // Storing top 3 interests as a JSON array
  paymentSettings Json?      // User's connected wallet/bank details
  settings      Json?        // User's app settings (notifications, privacy, etc.)
  
  // Status & Moderation
  isActive      Boolean      @default(true)
  isSuspended   Boolean      @default(false)
  isShadowBanned Boolean     @default(false)
  
  posts         Post[]
  engagements   Engagement[]
  transactions  Transaction[]
  
  // Admin Fields
  roleId        String?
  role          Role?        @relation(fields: [roleId], references: [id])
  
  followers     Follows[]    @relation("following")
  following     Follows[]    @relation("follower")
  
  notificationsReceived Notification[] @relation("ReceivedNotifications")
  notificationsSent     Notification[] @relation("SentNotifications")
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Follows {
  followerId  String
  followingId String
  follower    User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Post {
  id             Int          @id @default(autoincrement())
  content        String       @db.Text
  authorId       String
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  earned         Float        @default(0.0)
  viewsCount     Int          @default(0)
  // Media Fields
  mediaUrl       String?
  thumbnailUrl   String?
  mediaType      String?      // "IMAGE", "VIDEO"
  videoWidth     Int?
  videoHeight    Int?
  videoDuration  Int?
  
  // Monetization Flags
  isEligible     Boolean      @default(true)
  isFlagged      Boolean      @default(false)
  
  // Reply System (Tree structure)
  parentId       Int?
  conversationId Int?
  parent         Post?        @relation("PostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Post[]       @relation("PostReplies")
  
  // Quote System
  quotedPostId   Int?
  quotedPost     Post?        @relation("PostQuotes", fields: [quotedPostId], references: [id], onDelete: Cascade)
  quotes         Post[]       @relation("PostQuotes")
  
  engagements    Engagement[]
  notifications  Notification[]
  transactions   Transaction[]
  createdAt      DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Engagement {
  id        Int      @id @default(autoincrement())
  type      String   // "LIKE", "RESELA", "BOOKMARK"
  userId    String
  postId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId, type])
}

model Notification {
  id          Int      @id @default(autoincrement())
  recipientId String   // The user receiving the notification
  actorId     String   // The user performing the action
  type        String   // "LIKE", "RESELA", "REPLY", "QUOTE", "FOLLOW"
  postId      Int?     // The relevant post (if any)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  recipient   User     @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User     @relation("SentNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    Int?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  amount    Float
  type      String   // "IMPRESSION", "REPLY", "QUOTE", "POST", "RESELA", "WITHDRAWAL"
  status    String   @default("COMPLETED")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// -----------------------------------------------------------------------------
// SUPER ADMIN & RBAC MODELS
// -----------------------------------------------------------------------------

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // super_admin, support, moderator
  permissions Json?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  actorId         String
  actorRole       String?
  action          String
  resourceType    String
  resourceId      String?
  requestPayload  Json?
  responseStatus  Int?
  success         Boolean
  traceId         String?
  
  @@index([actorId, timestamp])
}

model ImpersonationToken {
  id           String   @id @default(uuid())
  actorId      String
  targetUserId String
  token        String   @unique
  reason       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Approval {
  id           String   @id @default(uuid())
  actionType   String
  payload      Json?
  requestedBy  String
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvers    Json?
  executedAt   DateTime?
  createdAt    DateTime @default(now())
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
