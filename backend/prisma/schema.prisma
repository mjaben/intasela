// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid())
  firstName     String
  lastName      String
  email         String       @unique
  pendingEmail  String?
  emailVerificationOtp String?
  phone         String?
  password      String
  username           String       @unique
  lastUsernameChange DateTime?
  avatarUrl          String?
  coverUrl           String?
  walletBalance      Float        @default(0.0)
  
  // Optional Onboarding Fields
  country       String?
  state         String?
  lga           String?
  occupation    String?
  gender        String?
  bio           String?      @db.Text
  creatorType   String?
  interests     Json?        // Storing top 3 interests as a JSON array
  paymentSettings Json?      // User's connected wallet/bank details
  settings      Json?        // User's app settings (notifications, privacy, etc.)
  
  // Status & Moderation
  isActive      Boolean      @default(true)
  isSuspended   Boolean      @default(false)
  isShadowBanned Boolean     @default(false)
  isSpaceMod    Boolean      @default(false)
  
  spaces        SpaceMember[]
  
  posts         Post[]
  engagements   Engagement[]
  transactions  Transaction[]
  pollVotes     PollVote[]
  
  // Removed Admin Fields (Segregated to SystemAdmin model)
  
  followers     Follows[]    @relation("following")
  following     Follows[]    @relation("follower")
  
  notificationsReceived Notification[] @relation("ReceivedNotifications")
  notificationsSent     Notification[] @relation("SentNotifications")
  
  advertiserProfiles    Advertiser[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Follows {
  followerId  String
  followingId String
  follower    User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Post {
  id             Int          @id @default(autoincrement())
  content        String       @db.Text
  authorId       String
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  earned         Float        @default(0.0)
  viewsCount     Int          @default(0)
  // Media Fields
  mediaUrl       String?
  mediaUrls      String[]     @default([])
  thumbnailUrl   String?
  mediaType      String?      // "IMAGE", "VIDEO"
  videoWidth     Int?
  videoHeight    Int?
  videoDuration  Int?
  
  // Space
  spaceId        String?
  space          Space?       @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  
  // Monetization Flags
  isEligible     Boolean      @default(true)
  isFlagged      Boolean      @default(false)
  approvalStatus String       @default("APPROVED") // "APPROVED", "PENDING", "REJECTED"
  
  // Post State & Scheduling
  status         String       @default("PUBLISHED") // "PUBLISHED", "DRAFT", "SCHEDULED"
  scheduledFor   DateTime?
  
  // Poll
  poll           Poll?
  
  // Reply System (Tree structure)
  parentId       Int?
  conversationId Int?
  parent         Post?        @relation("PostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Post[]       @relation("PostReplies")
  
  // Quote System
  quotedPostId   Int?
  quotedPost     Post?        @relation("PostQuotes", fields: [quotedPostId], references: [id], onDelete: Cascade)
  quotes         Post[]       @relation("PostQuotes")
  
  engagements    Engagement[]
  notifications  Notification[]
  transactions   Transaction[]
  createdAt      DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Engagement {
  id        Int      @id @default(autoincrement())
  type      String   // "LIKE", "RESELA", "BOOKMARK"
  userId    String
  postId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId, type])
}

model Notification {
  id          Int      @id @default(autoincrement())
  recipientId String   // The user receiving the notification
  actorId     String   // The user performing the action
  type        String   // "LIKE", "RESELA", "REPLY", "QUOTE", "FOLLOW"
  postId      Int?     // The relevant post (if any)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  recipient   User     @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User     @relation("SentNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  spaceId     String?
  space       Space?   @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    Int?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  amount    Float
  type      String   // "IMPRESSION", "REPLY", "QUOTE", "POST", "RESELA", "WITHDRAWAL"
  status    String   @default("COMPLETED")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// -----------------------------------------------------------------------------
// SPACE MODELS
// -----------------------------------------------------------------------------

model Space {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  coverUrl    String?
  type        String   @default("PUBLIC") // "PUBLIC" or "PRIVATE"
  postApprovalMode String @default("NONE") // "NONE", "ALL_POSTS", "FIRST_POST_ONLY"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  members     SpaceMember[]
  posts       Post[]
  notifications Notification[]
}

model SpaceMember {
  id            String   @id @default(uuid())
  spaceId       String
  userId        String
  role          String   @default("MEMBER") // "MEMBER", "MODERATOR", "ADMIN"
  permissions   Json?    // Array of permission strings e.g. ["MANAGE_MEMBERS", "MANAGE_POSTS", "EDIT_SPACE"]
  status        String   @default("ACTIVE") // "ACTIVE", "PENDING", "SUSPENDED", "APPEALED"
  hasApprovedPost Boolean @default(false)
  suspendReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([spaceId, userId])
}

// -----------------------------------------------------------------------------
// SUPER ADMIN & RBAC MODELS
// -----------------------------------------------------------------------------

model SystemAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String        @id @default(uuid())
  name        String        @unique // super_admin, moderator, finance
  permissions Json?         // Array of permission strings e.g. ["MANAGE_USERS", "MANAGE_FINANCE"]
  admins      SystemAdmin[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model AuditLog {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  actorId         String
  actorRole       String?
  action          String
  resourceType    String
  resourceId      String?
  requestPayload  Json?
  responseStatus  Int?
  success         Boolean
  traceId         String?
  
  @@index([actorId, timestamp])
}

model ImpersonationToken {
  id           String   @id @default(uuid())
  actorId      String
  targetUserId String
  token        String   @unique
  reason       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Approval {
  id           String   @id @default(uuid())
  actionType   String
  payload      Json?
  requestedBy  String
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvers    Json?
  executedAt   DateTime?
  createdAt    DateTime @default(now())
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// AD MANAGEMENT SYSTEM MODELS
// -----------------------------------------------------------------------------

model Advertiser {
  id           String     @id @default(uuid())
  companyName  String
  email        String     @unique
  phone        String?
  verified     Boolean    @default(false)
  userId       String?    
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  adWalletBalance Float   @default(0.0)
  campaigns    Campaign[]
  transactions AdvertiserTransaction[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AdvertiserTransaction {
  id           String      @id @default(uuid())
  advertiserId String
  advertiser   Advertiser  @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  amount       Float
  type         String      // "MANUAL_FUNDING", "CAMPAIGN_SPEND"
  status       String      @default("PENDING") // PENDING, COMPLETED, REJECTED
  reference    String?     // Sender name or bank reference
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  @@index([advertiserId, createdAt])
}

model Campaign {
  id              String      @id @default(uuid())
  advertiserId    String
  advertiser      Advertiser  @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  name            String
  budget          Float
  dailyBudget     Float?      @default(0) // Added for daily pacing
  remainingBudget Float
  status          String      @default("PENDING") // PENDING, ACTIVE, PAUSED, COMPLETED, REJECTED
  startDate       DateTime    @default(now())
  endDate         DateTime?
  bid             Float       // Target CPM
  objective       String?     // e.g., "AWARENESS", "CONVERSION"
  frequencyCap    Int         @default(3) // max impressions per user per 24h
  targetCountry   String?
  targetStates    String?     // Comma separated list of states/regions
  targetAge       String?
  targetGender    String?     // e.g., "ALL", "MALE", "FEMALE"
  interests       String?     // Comma separated list or JSON string
  keywords        String?     // Comma separated list of keywords
  creatives       Creative[]
  impressions     AdImpression[]
  clicks          AdClick[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Creative {
  id          String    @id @default(uuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  postId      Int?      // Link to an existing Post for business ads
  mediaUrl    String?   
  mediaType   String?   // "IMAGE", "VIDEO"
  headline    String?
  description String?   @db.Text
  ctaText     String?   
  ctaLink     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AdImpression {
  id          String   @id @default(uuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId      String?
  timestamp   DateTime @default(now())
  device      String?
  country     String?
  cost        Float    
  
  @@index([campaignId, timestamp])
  @@index([userId, timestamp])
}

model Poll {
  id        Int          @id @default(autoincrement())
  postId    Int          @unique
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options   PollOption[]
  expiresAt DateTime
  createdAt DateTime     @default(now())
}

model PollOption {
  id        Int        @id @default(autoincrement())
  pollId    Int
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text      String
  votes     Int        @default(0)
  userVotes PollVote[]
}

model PollVote {
  id           Int        @id @default(autoincrement())
  pollOptionId Int
  userId       String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([pollOptionId, userId])
}

model AdClick {
  id          String   @id @default(uuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId      String?
  timestamp   DateTime @default(now())
  ip          String?
  
  @@index([campaignId, timestamp])
  @@index([userId, timestamp])
}
